# Server
PORT=3000
MAX_AUDIO_FILE_SIZE_MB=200
STT_DEBUG_ENABLED=false
REVIEW_JOB_MODE=async
REVIEW_JOB_CONCURRENCY=1
REVIEW_JOB_MAX_PENDING=20
REVIEW_JOB_RESULT_TTL_MS=3600000
REVIEW_JOB_POLL_AFTER_MS=2500
REVIEW_JOB_STORE_BACKEND=memory
REDIS_URL=
REVIEW_JOB_REDIS_KEY_PREFIX=review_jobs
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REVIEW_CREATE=6
RATE_LIMIT_REVIEW_STATUS=180
RATE_LIMIT_ANALYZE=30

# Auth (Feishu Open Platform)
FEISHU_ENABLED=false
AUTH_REQUIRED=false
SESSION_TTL_SECONDS=43200
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=https://your-domain.com/auth/feishu/callback
FEISHU_SCOPE=contact:user.base:readonly
# FEISHU_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/index
# FEISHU_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v1/oidc/access_token
# FEISHU_USERINFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info
# Optional allow list (comma separated)
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_EMAILS=

# Feishu bot (event callback + audio review)
FEISHU_BOT_ENABLED=false
# webhook | long_connection
FEISHU_BOT_EVENT_MODE=webhook
# If empty, fallback to FEISHU_APP_ID / FEISHU_APP_SECRET
FEISHU_BOT_APP_ID=
FEISHU_BOT_APP_SECRET=
# Event subscription verification token (same as Feishu platform setting)
FEISHU_BOT_VERIFICATION_TOKEN=
FEISHU_BOT_RECEIVE_ID_TYPE=chat_id
FEISHU_BOT_REQUIRE_TEXT_WITH_AUDIO=false
FEISHU_BOT_REPLY_ENABLED=true
FEISHU_BOT_TEXT_CACHE_TTL_SECONDS=900
FEISHU_BOT_EVENT_TTL_SECONDS=600
FEISHU_BOT_MESSAGE_DEDUP_TTL_SECONDS=604800
FEISHU_BOT_MESSAGE_DEDUP_REDIS_PREFIX=feishu_bot_message_dedup
FEISHU_BOT_REPLY_MAX_LENGTH=3500
FEISHU_BOT_DOWNLOAD_TIMEOUT_MS=120000
FEISHU_BOT_REQUEST_TIMEOUT_MS=20000
FEISHU_BOT_PUBLIC_ORIGIN=
# FEISHU_BOT_TENANT_TOKEN_URL=https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal
# FEISHU_BOT_MESSAGE_REPLY_URL=https://open.feishu.cn/open-apis/im/v1/messages
# FEISHU_BOT_MESSAGE_RESOURCE_BASE_URL=https://open.feishu.cn/open-apis/im/v1/messages

# LLM provider selection: openai | anthropic | deepseek | doubao | qwen
ACTIVE_PROVIDER=deepseek

# OpenAI (optional)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=600000

# Anthropic (optional)
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_TIMEOUT_MS=600000

# Deepseek (recommended for current setup)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=600000

# Doubao / Qwen (optional)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# STT provider selection: doubao_asr_2 | qwen_fun_asr
STT_ACTIVE_PROVIDER=doubao_asr_2

# Volcengine ASR 2 (doubao_asr_2)
STT_DOUBAO_ASR_2_TYPE=volcengine-asr2
STT_DOUBAO_ASR_2_BASE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel
STT_DOUBAO_ASR_2_APP_ID=
STT_DOUBAO_ASR_2_ACCESS_TOKEN=
STT_DOUBAO_ASR_2_RESOURCE_ID=volc.seedasr.auc
STT_DOUBAO_ASR_2_MODEL_NAME=bigmodel
STT_DOUBAO_ASR_2_ENABLE_ITN=true
STT_DOUBAO_ASR_2_ENABLE_PUNC=true
STT_DOUBAO_ASR_2_ENABLE_SPEAKER_INFO=true
STT_DOUBAO_ASR_2_SHOW_UTTERANCES=true
# Railway 预发示例: https://your-service.up.railway.app
# 火山引擎生产示例: https://app.qjgroup.top
STT_DOUBAO_ASR_2_PUBLIC_BASE_URL=https://app.qjgroup.top
STT_DOUBAO_ASR_2_PUBLIC_PATH=/uploads
STT_DOUBAO_ASR_2_POLL_INTERVAL_MS=3000
STT_DOUBAO_ASR_2_POLL_MAX_ATTEMPTS=200
STT_DOUBAO_ASR_2_SUBMIT_MAX_ATTEMPTS=4
STT_DOUBAO_ASR_2_SUBMIT_RETRY_BACKOFF_MS=1200
STT_DOUBAO_ASR_2_SUBMIT_RETRY_MAX_BACKOFF_MS=15000

# Qwen FUN ASR (optional)
STT_QWEN_FUN_ASR_TYPE=dashscope-fun-asr
STT_QWEN_FUN_ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1
STT_QWEN_FUN_ASR_API_KEY=
STT_QWEN_FUN_ASR_MODEL=fun-asr
STT_QWEN_FUN_ASR_DIARIZATION_ENABLED=true
STT_QWEN_FUN_ASR_SPEAKER_COUNT=2
# Railway 预发示例: https://your-service.up.railway.app
# 火山引擎生产示例: https://app.qjgroup.top
STT_QWEN_FUN_ASR_PUBLIC_BASE_URL=https://app.qjgroup.top
STT_QWEN_FUN_ASR_PUBLIC_PATH=/uploads
STT_QWEN_FUN_ASR_POLL_INTERVAL_MS=2000
STT_QWEN_FUN_ASR_POLL_MAX_ATTEMPTS=30

# TOS (required: upload audio will be stored in TOS only)
TOS_ENABLED=true
TOS_BUCKET=
TOS_REGION=cn-shanghai
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_KEY_PREFIX=uploads
TOS_PRESIGN_EXPIRES=900

# Advanced override (optional): full JSON merged at the end
# AI_CONFIG_JSON={"active_provider":"openai","providers":{"openai":{"api_key":"xxx"}}}
