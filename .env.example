# Server
PORT=3000

# Auth (Feishu Open Platform)
FEISHU_ENABLED=false
AUTH_REQUIRED=false
SESSION_TTL_SECONDS=43200
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=https://your-domain.com/auth/feishu/callback
FEISHU_SCOPE=contact:user.base:readonly
# FEISHU_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/index
# FEISHU_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v1/oidc/access_token
# FEISHU_USERINFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info
# Optional allow list (comma separated)
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_EMAILS=

# LLM provider selection: openai | anthropic | deepseek | doubao | qwen
ACTIVE_PROVIDER=deepseek

# OpenAI (optional)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=600000

# Anthropic (optional)
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_TIMEOUT_MS=600000

# Deepseek (recommended for current setup)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=600000

# Doubao / Qwen (optional)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# STT provider selection: doubao_asr_2 | qwen_fun_asr
STT_ACTIVE_PROVIDER=doubao_asr_2

# Volcengine ASR 2 (doubao_asr_2)
STT_DOUBAO_ASR_2_TYPE=volcengine-asr2
STT_DOUBAO_ASR_2_BASE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel
STT_DOUBAO_ASR_2_APP_ID=
STT_DOUBAO_ASR_2_ACCESS_TOKEN=
STT_DOUBAO_ASR_2_RESOURCE_ID=volc.seedasr.auc
STT_DOUBAO_ASR_2_MODEL_NAME=bigmodel
STT_DOUBAO_ASR_2_ENABLE_ITN=true
STT_DOUBAO_ASR_2_ENABLE_PUNC=true
STT_DOUBAO_ASR_2_ENABLE_SPEAKER_INFO=true
STT_DOUBAO_ASR_2_SHOW_UTTERANCES=true
STT_DOUBAO_ASR_2_PUBLIC_BASE_URL=https://your-app.up.railway.app
STT_DOUBAO_ASR_2_PUBLIC_PATH=/uploads
STT_DOUBAO_ASR_2_POLL_INTERVAL_MS=3000
STT_DOUBAO_ASR_2_POLL_MAX_ATTEMPTS=200

# Qwen FUN ASR (optional)
STT_QWEN_FUN_ASR_TYPE=dashscope-fun-asr
STT_QWEN_FUN_ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1
STT_QWEN_FUN_ASR_API_KEY=
STT_QWEN_FUN_ASR_MODEL=fun-asr
STT_QWEN_FUN_ASR_DIARIZATION_ENABLED=true
STT_QWEN_FUN_ASR_SPEAKER_COUNT=2
STT_QWEN_FUN_ASR_PUBLIC_BASE_URL=https://your-app.up.railway.app
STT_QWEN_FUN_ASR_PUBLIC_PATH=/uploads
STT_QWEN_FUN_ASR_POLL_INTERVAL_MS=2000
STT_QWEN_FUN_ASR_POLL_MAX_ATTEMPTS=30

# TOS (optional, recommended for ASR URL fetch)
TOS_ENABLED=true
TOS_BUCKET=
TOS_REGION=cn-shanghai
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_KEY_PREFIX=uploads
TOS_PRESIGN_EXPIRES=900

# Advanced override (optional): full JSON merged at the end
# AI_CONFIG_JSON={"active_provider":"openai","providers":{"openai":{"api_key":"xxx"}}}
